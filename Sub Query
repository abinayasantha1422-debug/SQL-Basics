(3,'Raju','Science',82.2,'EEE'),
(4,'Ram','Maths',45.2,'Ece'),
(5,'Ramya','Science',95.2,'Cse');
select avg(sub_mark)from students ;
#avg sal=16250
# single row subquery
select  * from students
# multi row subquery 
where sub_mark>(select avg(sub_mark)from students);
select  * from students where sub_mark>50; 
